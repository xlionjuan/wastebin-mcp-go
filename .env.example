# Wastebin MCP Server Configuration
#
# Copy this file to .env and adjust values for your environment.
# The .env file is NOT read automatically — set these as environment variables
# in your MCP client configuration or shell.

# ── Required ─────────────────────────────────────────────────────────────────

# URL of the Wastebin server instance.
# Required - Wastebin server URL
# Use bin-staging.xlion.tw for testing; change to bin.xlion.tw for production
WASTEBIN_SERVER_URL=https://bin-staging.xlion.tw

# ── Optional (defaults shown) ────────────────────────────────────────────────

# Enable file-read mode, allowing the create_paste tool to read local files.
# Set to "false" to disable file reading entirely (only inline content mode).
# Default: true
# WASTEBIN_MCP_FILE_READ_ENABLED=true

# Default paste expiration in seconds when no expires parameter is given.
# Default: 31536000 (1 year)
# WASTEBIN_MCP_DEFAULT_EXPIRES=31536000

# Comma-separated list of absolute directory paths allowed for file reads.
# When file-read mode is enabled and this is empty, the server falls through
# to the blocklist pipeline (built-in + user blocklist). Only system
# directories and sensitive paths are blocked by default.
# Default: (empty — only built-in and user blocklists apply)
# WASTEBIN_MCP_ALLOWED_PATHS=/home/user/documents,/tmp

# Comma-separated list of absolute directory paths to block from file reads.
# The allowlist (ALLOWED_PATHS) takes precedence over entries in this list.
# Default: /etc,/proc,/sys,/dev
# WASTEBIN_MCP_BLOCKED_PATHS=/etc,/proc,/sys,/dev

# Maximum paste content size in bytes. Applied client-side before upload
# to fail fast on oversized content.
# Default: 1048576 (1 MB)
# WASTEBIN_MCP_MAX_CONTENT_SIZE=1048576

# Disable the built-in blocklist (/etc, /proc, /sys, /dev, .ssh, .gnupg).
# When true, only the user-configured blocklist (WASTEBIN_MCP_BLOCKED_PATHS)
# and allowlist (WASTEBIN_MCP_ALLOWED_PATHS) apply.
# Default: false
# WASTEBIN_MCP_DISABLE_BUILTIN_BLOCKLIST=true

# Sandbox mount mappings in Docker format: host_path:sandbox_path pairs,
# comma-separated. Enables sandbox-path translation for container deployments.
# Example: /home/user/workspace:/workspace
# Default: (empty — sandbox translation disabled)
# WASTEBIN_MCP_SANDBOX_MOUNTS=

# When true, sandbox path translation happens automatically without requiring
# an explicit parameter. The translate_sandbox_path parameter is hidden from
# the tool schema.
# Default: false
# WASTEBIN_MCP_SANDBOX_TRANSPARENT=false

# Enable debug logging (HTTP request/response details written to stderr).
# Set to "1" or "true" to enable. Same effect as --debug CLI flag.
# Default: (not set — debug logging disabled)
# DEBUG=1
